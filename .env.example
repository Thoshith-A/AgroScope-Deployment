# Frontend (Vite) — copy to .env and fill in. Never commit .env.

# Backend base URL (dev: leave empty to use Vite proxy to localhost:5000)
# VITE_API_URL=

# Google Maps API key (satellite map + verification screen location label)
# Get key: https://console.cloud.google.com/apis/credentials — enable Maps JavaScript API and Geocoding API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional: Supabase
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional: Socket URL (defaults to same origin in dev)
# VITE_SOCKET_URL=

# Verified crop waste capture: mock mode (dev only, no real camera/GPS)
# VITE_MOCK_CAPTURE=true
