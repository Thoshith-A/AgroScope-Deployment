# AgroScope Backend Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file itself

# DeepSeek AI API (get from platform.deepseek.com)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Tavily Search API (get from tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here

# OpenCage Geocoding API (required for location-based agri news)
OPENCAGE_API_KEY=your_opencage_api_key_here

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/agroscope

# JWT Authentication
JWT_SECRET=your_super_long_random_secret_string_here_minimum_32_chars
JWT_EXPIRES_IN=7d

# Server configuration
PORT=5000
NODE_ENV=development

# Frontend URL (set in Render production env for tighter CORS if needed)
FRONTEND_URL=https://your-frontend-domain.vercel.app

# Optional: Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Optional: OpenWeatherMap (if used)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Optional: Gemini (crop weight estimator + vision weight estimation)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
# Vision weight estimation (max image size in MB)
VISION_MAX_IMAGE_SIZE_MB=10

# Google Cloud Vision (Detect Crop Type via Camera)
# Use an API key from Cloud Console, or a service account JSON path for GOOGLE_APPLICATION_CREDENTIALS.
# Enable Vision API and billing: https://console.cloud.google.com/apis/library/vision.googleapis.com
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# Wallet & notifications (AgroScope balance wallet, withdrawals, receipts)
PLATFORM_FEE_PERCENT=30
# Email (withdrawal receipt)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
ADMIN_EMAIL=admin@agroscope.com
# WhatsApp (Twilio – withdrawal receipt)
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
